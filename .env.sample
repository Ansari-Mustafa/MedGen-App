# ─────────────────────────────────────────────────────────────
#  MedGen-v2 — Environment Variables
#  Copy this file to .env and fill in your values.
#  Location: project root  (same folder as alembic.ini)
# ─────────────────────────────────────────────────────────────


# ─── Supabase ────────────────────────────────────────────────
# Dashboard → your project → Settings (gear icon) → API
#
# "Project URL" field:
SUPABASE_URL=https://<project-ref>.supabase.co
#
# "Project API keys" section → "anon" row → value:
SUPABASE_ANON_KEY=eyJ...
#
# "Project API keys" section → "service_role" row → value:
SUPABASE_SERVICE_ROLE_KEY=eyJ...
#
# Settings → API → "JWT Settings" section → "JWT Secret" field.
# Only needed as fallback for HS256; JWKS is used by default.
SUPABASE_JWT_SECRET=


# ─── Database ────────────────────────────────────────────────
# Dashboard → your project → Settings → Database → "Connection string"
#   • Tab: "URI"
#   • Mode: "Transaction" (port 6543)  ← use this for the app
#   Replace [YOUR-PASSWORD] with the DB password you set.
#   Prepend "postgresql+asyncpg://" instead of "postgresql://"
#
# Example:
#   postgresql+asyncpg://postgres.abcxyz:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
#
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres

# For Alembic migrations use the "Session" pooler (port 5432) or direct connection:
# Run:  DATABASE_URL=postgresql://... alembic upgrade head


# ─── Redis (ARQ background jobs) ────────────────────────────
# Local dev default. For production use Upstash or a hosted Redis.
REDIS_URL=redis://localhost:6379


# ─── AI ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...


# ─── STT / Speech-to-Text ────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
DEEPGRAM_API_KEY=...
GOOGLE_API_KEY=...


# ─── Provider selection (swappable) ─────────────────────────
STT_PROVIDER=elevenlabs     # elevenlabs | deepgram | assemblyai
AI_PROVIDER=anthropic       # anthropic | openai
AI_MODEL=claude-opus-4-6


# ─── App ─────────────────────────────────────────────────────
DEBUG=false

# Public URL — used by the mobile app to form API + WebSocket URLs.
# Local dev: paste your ngrok HTTPS URL (run: ngrok http 8000).
# Mobile derives:
#   REST → API_BASE_URL + "/patients"
#   WS   → wss://... + "/ws/notifications?token=..."
#   SSE  → API_BASE_URL + "/jobs/{id}/stream?token=..."
API_BASE_URL=https://<your-ngrok-id>.ngrok.io
